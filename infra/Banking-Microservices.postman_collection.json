{
  "info": {
    "name": "Banking Microservices - Solace PubSub+",
    "description": "Complete API collection for testing all 4 banking microservices with Solace event-driven architecture",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Account Service",
      "item": [
        {
          "name": "Create Account (Sender)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerName\": \"Alice Johnson\",\n  \"email\": \"alice@example.com\",\n  \"accountType\": \"CHECKING\",\n  \"initialBalance\": 10000.00\n}"
            },
            "url": {"raw": "http://localhost:8081/api/accounts", "host": ["localhost"], "port": "8081", "path": ["api", "accounts"]}
          }
        },
        {
          "name": "Create Account (Receiver)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerName\": \"Bob Smith\",\n  \"email\": \"bob@example.com\",\n  \"accountType\": \"SAVINGS\",\n  \"initialBalance\": 2500.00\n}"
            },
            "url": {"raw": "http://localhost:8081/api/accounts", "host": ["localhost"], "port": "8081", "path": ["api", "accounts"]}
          }
        },
        {
          "name": "Get All Accounts",
          "request": {
            "method": "GET",
            "url": {"raw": "http://localhost:8081/api/accounts", "host": ["localhost"], "port": "8081", "path": ["api", "accounts"]}
          }
        },
        {
          "name": "Get Account by ID",
          "request": {
            "method": "GET",
            "url": {"raw": "http://localhost:8081/api/accounts/{{accountId}}", "host": ["localhost"], "port": "8081", "path": ["api", "accounts", "{{accountId}}"]}
          }
        },
        {
          "name": "Get Account by Number",
          "request": {
            "method": "GET",
            "url": {"raw": "http://localhost:8081/api/accounts/number/{{accountNumber}}", "host": ["localhost"], "port": "8081", "path": ["api", "accounts", "number", "{{accountNumber}}"]}
          }
        },
        {
          "name": "Deposit to Account",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 1000.00\n}"
            },
            "url": {"raw": "http://localhost:8081/api/accounts/{{accountId}}/deposit", "host": ["localhost"], "port": "8081", "path": ["api", "accounts", "{{accountId}}", "deposit"]}
          }
        },
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": {"raw": "http://localhost:8081/actuator/health", "host": ["localhost"], "port": "8081", "path": ["actuator", "health"]}
          }
        }
      ]
    },
    {
      "name": "Payment Service",
      "item": [
        {
          "name": "Initiate Payment (Success)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fromAccountId\": \"{{senderAccountNumber}}\",\n  \"toAccountId\": \"{{receiverAccountNumber}}\",\n  \"amount\": 500.00,\n  \"description\": \"Monthly rent payment\"\n}"
            },
            "url": {"raw": "http://localhost:8082/api/payments", "host": ["localhost"], "port": "8082", "path": ["api", "payments"]}
          }
        },
        {
          "name": "Initiate Payment (Insufficient Funds)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fromAccountId\": \"{{receiverAccountNumber}}\",\n  \"toAccountId\": \"{{senderAccountNumber}}\",\n  \"amount\": 999999.00,\n  \"description\": \"This should fail - insufficient balance\"\n}"
            },
            "url": {"raw": "http://localhost:8082/api/payments", "host": ["localhost"], "port": "8082", "path": ["api", "payments"]}
          }
        },
        {
          "name": "Get All Payments",
          "request": {
            "method": "GET",
            "url": {"raw": "http://localhost:8082/api/payments", "host": ["localhost"], "port": "8082", "path": ["api", "payments"]}
          }
        },
        {
          "name": "Get Payment by ID",
          "request": {
            "method": "GET",
            "url": {"raw": "http://localhost:8082/api/payments/{{paymentId}}", "host": ["localhost"], "port": "8082", "path": ["api", "payments", "{{paymentId}}"]}
          }
        },
        {
          "name": "Get Payments by Account",
          "request": {
            "method": "GET",
            "url": {"raw": "http://localhost:8082/api/payments/account/{{accountId}}", "host": ["localhost"], "port": "8082", "path": ["api", "payments", "account", "{{accountId}}"]}
          }
        }
      ]
    },
    {
      "name": "Notification Service",
      "item": [
        {
          "name": "Get All Notifications",
          "request": {
            "method": "GET",
            "url": {"raw": "http://localhost:8083/api/notifications", "host": ["localhost"], "port": "8083", "path": ["api", "notifications"]}
          }
        },
        {
          "name": "Get Notification Count",
          "request": {
            "method": "GET",
            "url": {"raw": "http://localhost:8083/api/notifications/count", "host": ["localhost"], "port": "8083", "path": ["api", "notifications", "count"]}
          }
        }
      ]
    },
    {
      "name": "Audit Service",
      "item": [
        {
          "name": "Get Recent Audit Logs",
          "request": {
            "method": "GET",
            "url": {"raw": "http://localhost:8084/api/audit", "host": ["localhost"], "port": "8084", "path": ["api", "audit"]}
          }
        },
        {
          "name": "Get Audit Stats",
          "request": {
            "method": "GET",
            "url": {"raw": "http://localhost:8084/api/audit/stats", "host": ["localhost"], "port": "8084", "path": ["api", "audit", "stats"]}
          }
        },
        {
          "name": "Get Audits by Event Type",
          "request": {
            "method": "GET",
            "url": {"raw": "http://localhost:8084/api/audit/type/ACCOUNT_CREATED", "host": ["localhost"], "port": "8084", "path": ["api", "audit", "type", "ACCOUNT_CREATED"]}
          }
        },
        {
          "name": "Get Audits by Source Service",
          "request": {
            "method": "GET",
            "url": {"raw": "http://localhost:8084/api/audit/service/account-service", "host": ["localhost"], "port": "8084", "path": ["api", "audit", "service", "account-service"]}
          }
        },
        {
          "name": "Get Failed Payment Audits",
          "request": {
            "method": "GET",
            "url": {"raw": "http://localhost:8084/api/audit/type/PAYMENT_FAILED", "host": ["localhost"], "port": "8084", "path": ["api", "audit", "type", "PAYMENT_FAILED"]}
          }
        },
        {
          "name": "Get Audits by Severity",
          "request": {
            "method": "GET",
            "url": {"raw": "http://localhost:8084/api/audit/severity/WARN", "host": ["localhost"], "port": "8084", "path": ["api", "audit", "severity", "WARN"]}
          }
        }
      ]
    }
  ]
}
